{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/playground",
      "destination": "/playground/playground.5ce75e5acf1b.html"
    },
    {
      "source": "/Yash-Gupta.pdf",
      "destination": "/resources/Yash Resume.pdf"
    },
    {
      "source": "/_next/image",
      "destination": "/api/next-image"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:avif|webp|png|jpg|jpeg|gif|ico|woff2|mp3|wav|pdf))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
